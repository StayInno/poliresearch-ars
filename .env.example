# Copy to .env and fill in. Only the LLM key is required for the `ask` pipeline;
# the verification commands (verify-doi, check-bibliography, gates) need nothing here.

# --- LLM provider (research agents) ---
# Backend is auto-detected: if ANTHROPIC_API_KEY is set -> Anthropic API; else if the
# `claude` CLI is installed -> Claude Code (uses your existing login, NO API key needed).
# Force one explicitly with POLIRESEARCH_LLM_BACKEND = claude_code | anthropic.
POLIRESEARCH_LLM_BACKEND=
ANTHROPIC_API_KEY=
POLIRESEARCH_MODEL=claude-opus-4-8
# The Falsifier (judge) deliberately uses a DIFFERENT model from the generator so the two
# don't share correlated errors. Override here:
POLIRESEARCH_FALSIFIER_MODEL=claude-sonnet-4-6

# --- Polite-pool contact for Crossref (recommended, not required) ---
# Crossref gives faster, more reliable service when you identify yourself.
CROSSREF_MAILTO=you@example.com

# --- Keyed paper sources (ALL DISABLED unless you set the key) ---
# Leave blank to keep a source off. Crossref/arXiv/PubMed/OpenAlex need no key and are always on.
# Run `python -m poliresearch sources` to see which are enabled.
SEMANTIC_SCHOLAR_API_KEY=
CORE_API_KEY=
ADS_API_KEY=
IEEE_API_KEY=
SPRINGER_API_KEY=
ELSEVIER_API_KEY=

# --- Domain profile ---
# The system ships as a CS/AI research system first. Options: cs_ai (default) | generic | biomed.
# cs_ai enables the empirical code-execution loop; biomed/generic are literature-only.
POLIRESEARCH_DOMAIN=cs_ai

# --- Optional knobs ---
# Directory holding your closed corpus of source documents.
POLIRESEARCH_CORPUS=./corpus
# Where run logs / world-model snapshots are written.
POLIRESEARCH_RUNS=./runs
